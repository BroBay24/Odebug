# ==========================================
# Odoo Debug MAS - Environment Configuration
# ==========================================

# LLM Backend: "ollama" for local, "openai" for API
LLM_BACKEND=ollama

# --- Ollama (Local LLM) ---
OLLAMA_HOST=http://localhost:11434
# Default/fallback model (used if per-agent model not set)
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Per-agent model configuration (multi-model MAS) ---
# Each agent uses a model suited to its role. Set any to override the default.
# Common model names for Ollama (after `ollama pull <name>`):
#   - qwen2.5-coder:7b                  (code-specific, 7B, ~5GB VRAM)
#   - deepseek-coder:6.7b               (code-specific, 6.7B, ~4.5GB)
#   - codellama:7b                      (code-specific, 7B, ~5GB)
#   - llama3.1:8b                       (general, 8B, ~6GB)
#   - yuxinlu1/gemma-4-12b-agentic-fable5-composer2.5-v2-3.5x-tau2-GGUF:Q4_K_M  (agentic, 12B, ~4.5GB)
AGENT_MODEL_ERROR_READER=qwen2.5-coder:7b
AGENT_MODEL_CODE_TRACER=qwen2.5-coder:7b
AGENT_MODEL_DOC_CHECKER=qwen2.5-coder:7b
AGENT_MODEL_SOLUTION_RECOMMENDER=qwen2.5-coder:7b
AGENT_MODEL_SINGLE=qwen2.5-coder:7b

# --- OpenAI-compatible API (fallback/testing) ---
# If LLM_BACKEND=openai, set these:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Odoo (Docker) ---
# Path to Odoo addons directory (mounted from Docker)
# Used by Code Tracer to read module files
ODOO_ADDONS_PATH=/home/bayfr24/odoo/addons

# --- Evaluation ---
# Path to dataset directory containing test cases
DATASET_PATH=/home/bayfr24/odoo-debug-mas/dataset
# Path to save evaluation results
RESULTS_PATH=/home/bayfr24/odoo-debug-mas/results
